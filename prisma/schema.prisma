// ============================================================================
// VietBridge AI V2 — Prisma Schema
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum PlanType {
  FREE
  PRO
  ENTERPRISE
  API
}

enum TaskType {
  TRANSLATION
  REPLY
  RISK
  LEARN
  SCAN
}

enum SceneType {
  GENERAL
  BUSINESS
  STAFF
  COUPLE
  RESTAURANT
  RENT
  HOSPITAL
  HOUSEKEEPING
}

// ============================================================================
// NextAuth — Core Authentication Tables
// ============================================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           String    @default("user")
  totalCalls     Int       @default(0)
  userLevel      Int       @default(1)
  createdAt      DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  conversations Conversation[]
  usageLogs     UsageLog[]
  llmLogs       LlmLog[]
  apiKeys       ApiKey[]

  @@index([email])
  @@index([userLevel])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// Billing & Subscription
// ============================================================================

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  plan                 PlanType @default(FREE)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// ============================================================================
// Conversation & Messages
// ============================================================================

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  taskType  TaskType
  sceneType SceneType @default(GENERAL)
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([taskType])
  @@index([createdAt])
}

model Message {
  id               String   @id @default(cuid())
  conversationId   String
  role             String   // "user" | "assistant"
  content          String   @db.Text
  metadata         Json?
  modelUsed        String?
  tokensPrompt     Int?
  tokensCompletion Int?
  cost             Float?
  latency          Int?     // milliseconds
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// ============================================================================
// Analytics & Usage
// ============================================================================

model UsageLog {
  id               String    @id @default(cuid())
  userId           String
  taskType         TaskType
  sceneType        SceneType @default(GENERAL)
  modelUsed        String
  tokensPrompt     Int
  tokensCompletion Int
  cost             Float
  latency          Int       // milliseconds
  riskScore        Int?
  ragHit           Boolean   @default(false)
  status           String    @default("ok")
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskType])
  @@index([createdAt])
  @@index([status])
}

// ============================================================================
// Knowledge Base (RAG)
// ============================================================================

model KnowledgeEntry {
  id           String  @id @default(cuid())
  category     String
  key          String
  valueZh      String  @db.Text
  valueVi      String  @db.Text
  numericValue Float?
  rangeMin     Float?
  rangeMax     Float?
  unit         String?
  confidence   Float
  source       String?
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([key])
  @@index([category, key])
}

// ============================================================================
// Risk Engine
// ============================================================================

model RiskRule {
  id             String  @id @default(cuid())
  name           String  @default("")
  rule           String  @db.Text
  category       String
  weight         Int
  severity       String
  action         String
  active         Boolean @default(true)
  triggers       Int     @default(0)
  falsePositives Int     @default(0)

  @@index([category])
  @@index([active])
}

// ============================================================================
// Course Management (越南语学习课程)
// ============================================================================

model Course {
  id              String    @id @default(cuid())
  category        String    @default("general")
  chinese         String
  vietnamese      String
  pronunciation   String    @default("")
  culturalNote    String    @db.Text @default("")
  exampleSentence String    @default("")
  difficulty      String    @default("beginner") // beginner | intermediate | advanced
  isDaily         Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category])
  @@index([difficulty])
  @@index([isDaily])
}

// ============================================================================
// Scene Phrase Management (场景学习短语)
// ============================================================================

model ScenePhrase {
  id        String   @id @default(cuid())
  scene     String   @default("general")
  vi        String
  zh        String
  pinyin    String   @default("")
  culture   String   @db.Text @default("")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scene])
  @@index([active])
}

// ============================================================================
// Prompt Management
// ============================================================================

model PromptVersion {
  id                String    @id @default(cuid())
  task              TaskType  @default(TRANSLATION)
  scene             SceneType @default(GENERAL)
  version           String
  systemPrompt      String    @db.Text
  taskPrompt        String    @db.Text
  scenePrompt       String    @db.Text
  changes           String    @db.Text
  status            String    @default("archived")
  abGroup           String?
  accuracyScore     Float?
  satisfactionScore Float?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([task, scene, version])
  @@index([task])
  @@index([scene])
  @@index([status])
}

// ============================================================================
// Model Routing
// ============================================================================

model ModelRoute {
  id            String    @id @default(cuid())
  taskType      TaskType
  sceneType     SceneType @default(GENERAL)
  primaryModel  String
  fallbackModel String?
  maxCost       Float
  maxLatency    Int       // milliseconds
  active        Boolean   @default(true)
  userLevel     Int       @default(0)  // 0=all levels, 1-6=specific level

  @@index([taskType, sceneType])
  @@index([active])
  @@index([userLevel])
}

// ============================================================================
// LLM Call Logging (detailed per-call audit)
// ============================================================================

model LlmLog {
  id               String    @id @default(cuid())
  userId           String
  taskType         TaskType
  sceneType        SceneType @default(GENERAL)
  modelUsed        String
  input            String    @db.Text
  promptLayers     String    @db.Text
  output           String    @db.Text
  tokensPrompt     Int
  tokensCompletion Int
  cost             Float
  latency          Int       // milliseconds
  riskScore        Int       @default(0)
  ragHit           Boolean   @default(false)
  status           String    @default("ok")
  deleted          Boolean   @default(false)
  entryHash        String?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskType])
  @@index([createdAt])
  @@index([status])
  @@index([deleted])
}

// ============================================================================
// API Key Management
// ============================================================================

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  name      String
  keyHash   String   @unique
  prefix    String   // first 8 chars for identification
  calls     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@index([prefix])
}

// ============================================================================
// Admin RBAC
// ============================================================================

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[]
  userIds     String[]
}

// ============================================================================
// Model Pricing (财务管理)
// ============================================================================

model ModelPrice {
  id          String   @id @default(cuid())
  modelName   String   @unique
  displayName String   @default("")
  provider    String   @default("")
  inputPrice  Float    @default(0)   // USD per 1K input tokens
  outputPrice Float    @default(0)   // USD per 1K output tokens
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================================
// TTS Configuration (多模型 TTS 路由)
// ============================================================================

model TtsModel {
  id          String   @id @default(cuid())
  name        String   @unique            // 唯一标识: cosyvoice-v1, edge-tts, etc.
  displayName String   @default("")       // 显示名: CosyVoice, Edge TTS
  provider    String   @default("dashscope") // dashscope, edge, openai
  apiModel    String   @default("cosyvoice-v1") // API 模型名
  apiEndpoint String   @default("")       // 自定义端点 (空=使用默认)
  apiKeyEnv   String   @default("DASHSCOPE_API_KEY") // 环境变量名
  voiceZh     String   @default("longxiaochun")
  voiceVi     String   @default("longxiaochun")
  speed       Float    @default(1.0)
  isDefault   Boolean  @default(false)    // 是否为默认 TTS
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([isDefault])
}
