// ============================================================================
// VietBridge AI V2 — Prisma Schema
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum PlanType {
  FREE
  PRO
  ENTERPRISE
  API
}

enum TaskType {
  TRANSLATION
  REPLY
  RISK
  LEARN
  SCAN
}

enum SceneType {
  GENERAL
  BUSINESS
  STAFF
  COUPLE
  RESTAURANT
  RENT
  HOSPITAL
  REPAIR
}

// ============================================================================
// NextAuth — Core Authentication Tables
// ============================================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           String    @default("user")

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  conversations Conversation[]
  usageLogs     UsageLog[]
  llmLogs       LlmLog[]
  apiKeys       ApiKey[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// Billing & Subscription
// ============================================================================

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  plan                 PlanType @default(FREE)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// ============================================================================
// Conversation & Messages
// ============================================================================

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  taskType  TaskType
  sceneType SceneType @default(GENERAL)
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([taskType])
  @@index([createdAt])
}

model Message {
  id               String   @id @default(cuid())
  conversationId   String
  role             String   // "user" | "assistant"
  content          String   @db.Text
  metadata         Json?
  modelUsed        String?
  tokensPrompt     Int?
  tokensCompletion Int?
  cost             Float?
  latency          Int?     // milliseconds
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// ============================================================================
// Analytics & Usage
// ============================================================================

model UsageLog {
  id               String    @id @default(cuid())
  userId           String
  taskType         TaskType
  sceneType        SceneType @default(GENERAL)
  modelUsed        String
  tokensPrompt     Int
  tokensCompletion Int
  cost             Float
  latency          Int       // milliseconds
  riskScore        Int?
  ragHit           Boolean   @default(false)
  status           String    @default("ok")
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskType])
  @@index([createdAt])
  @@index([status])
}

// ============================================================================
// Knowledge Base (RAG)
// ============================================================================

model KnowledgeEntry {
  id           String  @id @default(cuid())
  category     String
  key          String
  valueZh      String  @db.Text
  valueVi      String  @db.Text
  numericValue Float?
  rangeMin     Float?
  rangeMax     Float?
  unit         String?
  confidence   Float
  source       String?
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([key])
  @@index([category, key])
}

// ============================================================================
// Risk Engine
// ============================================================================

model RiskRule {
  id             String  @id @default(cuid())
  rule           String  @db.Text
  category       String
  weight         Int
  severity       String
  action         String
  active         Boolean @default(true)
  triggers       Int     @default(0)
  falsePositives Int     @default(0)

  @@index([category])
  @@index([active])
}

// ============================================================================
// Prompt Management
// ============================================================================

model PromptVersion {
  id                String   @id @default(cuid())
  version           String
  changes           String   @db.Text
  status            String   @default("archived")
  abGroup           String?
  accuracyScore     Float?
  satisfactionScore Float?
  createdAt         DateTime @default(now())

  @@index([version])
  @@index([status])
}

// ============================================================================
// Model Routing
// ============================================================================

model ModelRoute {
  id            String    @id @default(cuid())
  taskType      TaskType
  sceneType     SceneType @default(GENERAL)
  primaryModel  String
  fallbackModel String?
  maxCost       Float
  maxLatency    Int       // milliseconds
  active        Boolean   @default(true)

  @@index([taskType, sceneType])
  @@index([active])
}

// ============================================================================
// LLM Call Logging (detailed per-call audit)
// ============================================================================

model LlmLog {
  id               String    @id @default(cuid())
  userId           String
  taskType         TaskType
  sceneType        SceneType @default(GENERAL)
  modelUsed        String
  input            String    @db.Text
  promptLayers     String    @db.Text
  output           String    @db.Text
  tokensPrompt     Int
  tokensCompletion Int
  cost             Float
  latency          Int       // milliseconds
  riskScore        Int       @default(0)
  ragHit           Boolean   @default(false)
  status           String    @default("ok")
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskType])
  @@index([createdAt])
  @@index([status])
}

// ============================================================================
// API Key Management
// ============================================================================

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  name      String
  keyHash   String   @unique
  prefix    String   // first 8 chars for identification
  calls     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@index([prefix])
}

// ============================================================================
// Admin RBAC
// ============================================================================

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[]
  userIds     String[]
}
